# Backend API Configuration
# Use relative paths so the app works behind a reverse proxy on any domain.
# For local development without a proxy, override with:
#   VITE_API_URL=http://localhost:3001/api
#   VITE_WS_URL=http://localhost:3001
VITE_API_URL=/api
VITE_WS_URL=

# Development Configuration
VITE_NODE_ENV=development
